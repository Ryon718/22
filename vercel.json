{
  "version": 2,
  "builds": [
    {
      "src": "api/voice-handler.js", // <-- 确认路径是否正确！
      "use": "@vercel/node"        // <-- 确保这个是 @vercel/node，而不是其他环境
    }
  ],
  "routes": [
    {
      "src": "/",                 // 匹配根路径：访问 https://your-app-name.vercel.app/ 时
      "dest": "api/voice-handler.js" // 将请求导向你的文件
    },
    {
      "src": "/api/(.*)",         // 匹配所有以 /api/ 开头的请求，例如 /api/test
      "dest": "api/voice-handler.js" // 也将这些请求导向你的文件
    }
  ]
}
